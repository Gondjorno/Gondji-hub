-- Авто-притягивание сундуков
local autoPullChestsEnabled = false
ChestsSection:NewToggle("Авто-притягивание сундуков", "Автоматически притягивает сундуки к игроку", function(state)
    autoPullChestsEnabled = state
    
    if state then
        spawn(function()
            while autoPullChestsEnabled do
                wait(3) -- Проверка каждые 3 секунды
                
                local chests = findChests()
                local playerPos = game.Players.LocalPlayer.Character.HumanoidRootPart.Position
                
                for i, chest in pairs(chests) do
                    if not autoPullChestsEnabled then break end
                    
                    -- Проверяем расстояние до сундука
                    local chestPos = chest:GetPivot().Position
                    local distance = (playerPos - chestPos).Magnitude
                    
                    -- Если сундук далеко, притягиваем его
                    if distance > 20 then
                        local angle = (i / #chests) * math.pi * 2
                        local radius = 4
                        local offset = Vector3.new(math.cos(angle) * radius, 2, math.sin(angle) * radius)
                        local targetPosition = playerPos + offset
                        
                        if chest:FindFirstChild("PrimaryPart") then
                            chest:PivotTo(CFrame.new(targetPosition))
                        else
                            local chestCFrame = chest:GetPivot()
                            chest:PivotTo(CFrame.new(targetPosition) * (chestCFrame - chestCFrame.Position))
                        end
                    end
                end
            end
        end)
    end
end)

