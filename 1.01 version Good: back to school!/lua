local ChestsSection = TeleportTab:NewSection("Сундуки и Drop Zone")

-- Функция для поиска сундуков
local function findChests()
    local chests = {}
    
    -- Поиск всех сундуков Chest1 в Workspace
    for _, obj in pairs(game.Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name == "Chest1" then
            table.insert(chests, obj)
        end
    end
    
    return chests
end

-- Функция для поиска предметов Item (от 1 до 40)
local function findItems()
    local items = {}
    
    -- Поиск предметов с именами Item1, Item2, ..., Item40
    for i = 1, 40 do
        local itemName = "Item" .. i
        for _, obj in pairs(game.Workspace:GetDescendants()) do
            if obj:IsA("Model") and obj.Name == itemName then
                table.insert(items, obj)
            end
        end
    end
    
    -- Также ищем просто "Item" на случай если есть без номера
    for _, obj in pairs(game.Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name == "Item" then
            table.insert(items, obj)
        end
    end
    
    return items
end

-- Функция для определения моего Drop Zone через LocalScript
local function findMyDropZone()
    local player = game.Players.LocalPlayer
    
    -- Поиск в лодке игрока
    for _, obj in pairs(game.Workspace:GetDescendants()) do
        if obj:IsA("Part") and obj.Name == "DropZone" then
            -- Проверяем, принадлежит ли эта лодка игроку через родительские объекты
            local parentModel = obj:FindFirstAncestorOfClass("Model")
            if parentModel then
                -- Проверяем наличие скриптов лодки
                local boatControl = parentModel:FindFirstChild("BoatControl")
                if boatControl then
                    -- Проверяем, есть ли LocalScript, который может указывать на владельца
                    local localScripts = parentModel:GetDescendants()
                    for _, script in pairs(localScripts) do
                        if script:IsA("LocalScript") then
                            -- Предполагаем, что лодка с LocalScript принадлежит текущему игроку
                            return obj
                        end
                    end
                end
            end
        end
    end
    
    return nil
end

-- Телепорт всех сундуков к себе
ChestsSection:NewButton("Притянуть все сундуки", "Телепортирует все сундуки к игроку", function()
    local chests = findChests()
    local playerPos = game.Players.LocalPlayer.Character.HumanoidRootPart.Position
    
    for i, chest in pairs(chests) do
        -- Создаем позицию вокруг игрока
        local angle = (i / #chests) * math.pi * 2
        local radius = 5
        local offset = Vector3.new(math.cos(angle) * radius, 3, math.sin(angle) * radius)
        local targetPosition = playerPos + offset
        
        -- Перемещаем сундук
        if chest:FindFirstChild("PrimaryPart") then
            chest:PivotTo(CFrame.new(targetPosition))
        else
            -- Если нет PrimaryPart, перемещаем все части
            local chestCFrame = chest:GetPivot()
            chest:PivotTo(CFrame.new(targetPosition) * (chestCFrame - chestCFrame.Position))
        end
    end
end)

