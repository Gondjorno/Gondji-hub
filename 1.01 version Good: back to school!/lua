-- Телепорт к моему Drop Zone
ChestsSection:NewButton("Телепорт к моему Drop Zone", "Телепортирует к вашей зоне высадки", function()
    local myDropZone = findMyDropZone()
    if myDropZone then
        game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(myDropZone.Position + Vector3.new(0, 5, 0))
    else
        -- Если не нашли свою Drop Zone, ищем любую доступную
        for _, obj in pairs(game.Workspace:GetDescendants()) do
            if obj:IsA("Part") and obj.Name == "DropZone" then
                game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(obj.Position + Vector3.new(0, 5, 0))
                break
            end
        end
    end
end)

-- Функция для поиска всех Drop Zones
local function findAllDropZones()
    local dropZones = {}
    
    for _, obj in pairs(game.Workspace:GetDescendants()) do
        if obj:IsA("Part") and obj.Name == "DropZone" then
            table.insert(dropZones, obj)
        end
    end
    
    return dropZones
end

-- Телепорт к ближайшей Drop Zone
ChestsSection:NewButton("Телепорт к ближайшей Drop Zone", "Телепортирует к ближайшей зоне высадки", function()
    local playerPos = game.Players.LocalPlayer.Character.HumanoidRootPart.Position
    local allDropZones = findAllDropZones()
    local closestDropZone = nil
    local closestDistance = math.huge
    
    for _, dropZone in pairs(allDropZones) do
        local distance = (playerPos - dropZone.Position).Magnitude
        if distance < closestDistance then
            closestDistance = distance
            closestDropZone = dropZone
        end
    end
    
    if closestDropZone then
        game.Players.LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(closestDropZone.Position + Vector3.new(0, 5, 0))
    end
end)

